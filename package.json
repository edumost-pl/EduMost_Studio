{
  "name": "edumost-studio",
  "version": "0.1.0",
  "description": "EduMost Studio — personal knowledge base for school curriculum",
  "main": "dist-electron/main.js",
  "author": "EduMost",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE vite",
    "build": "tsc -b && vite build",
    "dist": "npm run build && electron-builder --mac",
    "dist:dir": "npm run build && electron-builder --mac dir",
    "preview": "vite preview",
    "electron:dev": "env -u ELECTRON_RUN_AS_NODE vite",
    "electron:build": "npm run dist",
    "typecheck": "tsc -b --noEmit",
    "icons:mac": "bash scripts/build-mac-icon.sh",
    "db:verify": "ELECTRON_RUN_AS_NODE=1 electron --import tsx scripts/verify-db.ts",
    "db:apply-klasa5": "ELECTRON_RUN_AS_NODE=1 electron --import tsx scripts/apply-klasa5-seed.ts",
    "db:migrate-global-codes": "ELECTRON_RUN_AS_NODE=1 electron --import tsx scripts/migrate-global-topic-codes.ts",
    "postinstall": "electron-builder install-app-deps",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "exceljs": "^4.4.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.21",
    "electron": "^36.4.0",
    "electron-builder": "^26.0.12",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "com.edumost.studio",
    "productName": "EduMost Studio",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "node_modules/better-sqlite3/**/*"
    ],
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ],
    "mac": {
      "category": "public.app-category.education",
      "icon": "build/icon.icns",
      "target": [
        "dmg"
      ]
    }
  }
}
